## -----------------------------------------------------------------------------
## General / Main settings
## -----------------------------------------------------------------------------

## Minecraft/update compatibility.
# MC_GAME_VERSION=1.21.6
# MC_SERVER_LOADER=fabric
# MC_UPDATER_PLATFORMS=fabric,velocity,paper

## Main server jar. mc-updater can write SERVER_JAR for you when using --env-key.
# SERVER_JAR=fabric-server-launch.jar
# SERVER_WORKING_DIR=.
# SERVER_JAVA_OPTS=-Xms2G -Xmx4G
# SERVER_ARGS=nogui

## Startup topology.
# START_SERVER_ON_BOOT=false
# START_SERVICES_ON_BOOT=true

## Service format: name|working_dir|jar_path|java_opts|jar_args
## Multiple services are separated with semicolons. Empty means no services.
## mc-updater can uncomment/update this automatically for PaperMC Velocity.
# SERVICES_CONFIG=velocity|velocity|velocity.jar|-Xms512M -Xmx1G|

## -----------------------------------------------------------------------------
## Other settings
## -----------------------------------------------------------------------------

# JAVA_BIN=java
# SERVER_NAME=server
# PREFIX_OUTPUT=true
# SERVER_STOP_TIMEOUT=60
# SERVICE_STOP_TIMEOUT=15
# EXIT_TERM_TIMEOUT=5
# RUNTIME_DIR=.runtime
# TMUX_SESSION=minecraft

## -----------------------------------------------------------------------------
## Docker / Compose
## -----------------------------------------------------------------------------

# MINECRAFT_PORT=25565
# MINECRAFT_CONTAINER_PORT=25565
# DOCKER_BASE_IMAGE=ghcr.io/graalvm/jdk-community:25-ol9
# START_COMMAND=./start.sh
# CONTAINER_NAME=minecraft-server
# PUID=1000
# PGID=1000
# MC_HEALTHCHECK_ENABLED=true
# MC_HEALTHCHECK_PORT=25565

## -----------------------------------------------------------------------------
## Updater
## -----------------------------------------------------------------------------

# MC_UPDATER_TRACKING_FILE=mc-updater.json
# MC_UPDATER_DEST_DIR=mods
# MC_UPDATER_DEFAULT_VERSION=latest_any
# MC_UPDATER_DRY_RUN=false
# MC_UPDATER_DISABLE_SUFFIX=.disabled
# MC_UPDATER_REMOVE_OLD=true
# MC_UPDATER_UPDATE_ENV=true
# MC_UPDATER_UPDATE_ENV_REFERENCES=true
# MC_UPDATER_ENV_FILE=.env
# MC_UPDATER_UPDATE_SERVICES_CONFIG=true

## API defaults. Usually leave these commented.
# FABRIC_META_BASE=https://meta.fabricmc.net/v2/versions
# MODRINTH_API_BASE=https://api.modrinth.com/v2
# MODRINTH_USER_AGENT=mc-updater/1.0
# CURSEFORGE_API_BASE=https://api.curseforge.com/v1
# CURSEFORGE_API_KEY=
# CURSEFORGE_MODLOADER_TYPE=auto
# PAPERMC_API_BASE=https://fill.papermc.io/v3
# PAPERMC_USER_AGENT=mc-updater/1.0

## -----------------------------------------------------------------------------
## Backups
## -----------------------------------------------------------------------------

# MC_BACKUP_DIR=./backups
# MC_BACKUP_NAME=minecraft-server
# MC_BACKUP_TIMEZONE=Europe/Paris
# MC_BACKUP_WORLDS=world
# MC_BACKUP_FORMAT=auto
# MC_BACKUP_EXCLUDES=.runtime,backups

# MC_BACKUP_GRACE_SECONDS=10
# MC_BACKUP_SAVE_WAIT_SECONDS=5
# MC_BACKUP_STOP_WAIT_SECONDS=20
# MC_BACKUP_FULL_STOP_SERVER=true
# MC_BACKUP_WORLDS_STOP_SERVER=false
# MC_BACKUP_RESTART_AFTER_STOP=true
# MC_BACKUP_RESTART_AFTER_RESTORE=true
# MC_BACKUP_CONFIRM_RESTORE=true

## auto tries the launcher control FIFO first, then tmux. none disables it.
# MC_BACKUP_NOTIFY_METHOD=auto
# MC_BACKUP_CONTROL_METHOD=auto
# MC_BACKUP_CONTROL_SCRIPT=./start.sh
# MC_BACKUP_START_COMMAND=bash start.sh start
# MC_BACKUP_STOP_COMMAND=bash start.sh stop

# MC_BACKUP_MESSAGE_START=Backup in {seconds}s. The server may pause or restart.
# MC_BACKUP_MESSAGE_RUNNING=Backup in progress. Auto-save is temporarily disabled.
# MC_BACKUP_MESSAGE_DONE=Backup finished in {elapsed}s. Auto-save is enabled again.
# MC_BACKUP_MESSAGE_RESTART=Server restarting for backup in {seconds}s.
# MC_BACKUP_MESSAGE_FAILED=Backup failed. Auto-save is enabled again.

## -----------------------------------------------------------------------------
## Dynmap
## -----------------------------------------------------------------------------

# DYNMAP_WEB_SOURCE=dynmap/web
# DYNMAP_REMOTE_HOST=user@example.com
# DYNMAP_REMOTE_WEB_LOCATION=/home/user/.nginx/html/dynmap

# DYNMAP_DB_HOST=example.com
# DYNMAP_DB_PORT=3306
# DYNMAP_DB_USER=dynmap
# DYNMAP_DB_NAME=dynmap
# DYNMAP_DB_PASSWORD=
# DYNMAP_RESET_TABLES=Faces,Maps,MarkerFiles,MarkerIcons,SchemaVersion,StandaloneFiles,Tiles
# DYNMAP_CONFIRM_RESET=false

## -----------------------------------------------------------------------------
## Shared environment loading
## -----------------------------------------------------------------------------

# DOTENV_FILE=.env
# LOAD_DOTENV=true
# COMMON_FILE=./mc-common.sh
