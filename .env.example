# Optional: override which env file helper scripts load.
# DOTENV_FILE=.env

# Optional: disable .env loading.
# LOAD_DOTENV=true

# Optional: override the shared helper file path.
# COMMON_FILE=./mc-common.sh


# ==============================================================================
# start.sh - main launcher
# ==============================================================================

# Base directory used by start.sh for relative paths.
# Usually leave empty/default when running directly from the server directory.
# In Docker, /minecraft is the container workdir.
# BASE_DIR=/minecraft

JAVA_BIN=java

SERVER_NAME=server
SERVER_WORKING_DIR=.
SERVER_JAR=fabric-server-launch.jar
SERVER_JAVA_OPTS=-Xms2G -Xmx4G
SERVER_ARGS=nogui

# If false, only services such as Velocity start on boot.
# AutoServer can later call: bash start.sh start
START_SERVER_ON_BOOT=false
START_SERVICES_ON_BOOT=true

# Prefix combined logs with [server], [velocity], etc.
PREFIX_OUTPUT=true

SERVER_STOP_TIMEOUT=60
SERVICE_STOP_TIMEOUT=15
EXIT_TERM_TIMEOUT=5

# Optional: where start.sh stores FIFOs/lock files.
# Default is $BASE_DIR/.runtime.
# RUNTIME_DIR=/tmp/minecraft-launcher

# Services format:
#   name|working_dir|jar_path|java_opts|jar_args
#
# Multiple services are separated with semicolons.
# Example with Velocity in ./velocity/velocity.jar:
SERVICES_CONFIG=velocity|velocity|velocity.jar|-Xms512M -Xmx1G|


# ==============================================================================
# Docker / docker-compose.yml
# ==============================================================================

CONTAINER_NAME=minecraft-server
PUID=1000
PGID=1000

# Host directory mounted at /minecraft in the container.
MINECRAFT_DATA_DIR=.

# Host port:container port.
MINECRAFT_PORT=25565
MINECRAFT_CONTAINER_PORT=25565

# Command run inside Docker's tmux session.
START_COMMAND=./start.sh


# ==============================================================================
# mc-backup.sh - backup / restore helper
# ==============================================================================

MC_BACKUP_SERVER_DIR=.
MC_BACKUP_DIR=./backups
MC_BACKUP_NAME=minecraft-server
MC_BACKUP_TIMEZONE=Europe/Paris

# Comma-separated world directories, relative to MC_BACKUP_SERVER_DIR unless absolute.
MC_BACKUP_WORLDS=world

# auto = zip if available, otherwise tar.gz.
MC_BACKUP_FORMAT=auto

# Comma-separated exclude patterns for full backups.
MC_BACKUP_EXCLUDES=.runtime,backups

MC_BACKUP_GRACE_SECONDS=10
MC_BACKUP_SAVE_WAIT_SECONDS=5
MC_BACKUP_STOP_WAIT_SECONDS=20

# Full backups usually stop the server; worlds backups usually use save-off/save-on.
MC_BACKUP_FULL_STOP_SERVER=true
MC_BACKUP_WORLDS_STOP_SERVER=false
MC_BACKUP_RESTART_AFTER_STOP=true
MC_BACKUP_RESTART_AFTER_RESTORE=true
MC_BACKUP_CONFIRM_RESTORE=true

# Notification/control methods:
#   auto         try start-script, then tmux
#   start-script use MC_BACKUP_CONTROL_SCRIPT
#   tmux         send keys directly to MC_BACKUP_TMUX_SESSION
#   none         disable
MC_BACKUP_NOTIFY_METHOD=auto
MC_BACKUP_CONTROL_METHOD=auto
MC_BACKUP_CONTROL_SCRIPT=./start.sh
MC_BACKUP_TMUX_SESSION=minecraft

# Optional custom shell commands. If set, they override control method start/stop.
# MC_BACKUP_START_COMMAND=bash start.sh start
# MC_BACKUP_STOP_COMMAND=bash start.sh stop

MC_BACKUP_MESSAGE_START=Backup in {seconds}s. The server may pause or restart.
MC_BACKUP_MESSAGE_RUNNING=Backup in progress. Auto-save is temporarily disabled.
MC_BACKUP_MESSAGE_DONE=Backup finished in {elapsed}s. Auto-save is enabled again.
MC_BACKUP_MESSAGE_RESTART=Server restarting for backup in {seconds}s.


# ==============================================================================
# mc-dynmap.sh - Dynmap web upload / SQL reset helper
# ==============================================================================

DYNMAP_WEB_SOURCE=dynmap/web
DYNMAP_REMOTE_HOST=user@example.com
DYNMAP_REMOTE_WEB_LOCATION=/home/user/.nginx/html/dynmap

DYNMAP_DB_HOST=example.com
DYNMAP_DB_PORT=3306
DYNMAP_DB_USER=dynmap
DYNMAP_DB_NAME=dynmap

# Optional. If empty/omitted, mysql prompts for the password.
DYNMAP_DB_PASSWORD=

DYNMAP_RESET_TABLES=Faces,Maps,MarkerFiles,MarkerIcons,SchemaVersion,StandaloneFiles,Tiles
DYNMAP_CONFIRM_RESET=false


# ==============================================================================
# mc-updater.sh - unified updater
# ==============================================================================

MC_UPDATER_TRACKING_FILE=mc-updater.json
MC_GAME_VERSION=1.21.6
MC_SERVER_LOADER=fabric
MC_UPDATER_DEST_DIR=mods
MC_UPDATER_RELEASE_TYPES=release,beta
MC_UPDATER_DRY_RUN=false
MC_UPDATER_DISABLE_SUFFIX=.disabled
MC_UPDATER_REMOVE_OLD=true
MC_UPDATER_UPDATE_ENV=true
MC_UPDATER_ENV_FILE=.env

# API bases. Usually leave these alone.
FABRIC_META_BASE=https://meta.fabricmc.net/v2/versions
MODRINTH_API_BASE=https://api.modrinth.com/v2
MODRINTH_USER_AGENT=mc-updater/1.0
CURSEFORGE_API_BASE=https://api.curseforge.com/v1
PAPERMC_API_BASE=https://api.papermc.io/v2

# Required only for CurseForge entries.
CURSEFORGE_API_KEY=

# auto maps common loaders:
#   forge -> 1
#   fabric -> 4
#   quilt -> 5
#   neoforge -> 6
CURSEFORGE_MODLOADER_TYPE=auto
